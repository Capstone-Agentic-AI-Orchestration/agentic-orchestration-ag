EVE_MODEL="openai/gpt-5.4-mini"
EVE_BACKEND_MODEL=""
EVE_FRONTEND_MODEL=""
EVE_MOBILE_MODEL=""
EVE_DATABASE_MODEL=""
EVE_ARCHITECTURE_MODEL=""
EVE_REQUIREMENTS_MODEL=""
EVE_CONTRACT_MODEL=""
EVE_CRITIQUE_MODEL=""

# Optional for local dev. When set, /eve/v1 routes require:
# Authorization: Bearer <EVE_SERVICE_TOKEN>
# Must match EVE_SERVICE_TOKEN on agentic-orchestration-be.
EVE_SERVICE_TOKEN=""

# ─── Repository access (read / edit / push) ───────────────────────────────────
# Required for the list_repo_files, read_repo_file, and write_repo_files tools.
# This service holds NO GitHub credentials: it calls the DevFlow backend, which resolves
# the turn's token to a project and performs the GitHub operation under its own App
# installation. Leave these empty to disable repository access — subagents then generate
# from the contract alone, exactly as before.

# Base URL of agentic-orchestration-be (no trailing slash). The local default assumes the
# backend's PORT=4000.
DEVFLOW_API_URL="http://127.0.0.1:4000"

# Shared service secret. Generate a long random value and set the SAME value on
# agentic-orchestration-be. This authenticates the service; per-project scope is enforced
# separately by the per-run token the backend puts in each turn's prompt.
AGENT_REPO_SERVICE_TOKEN=""

# ─── Local dev port ───────────────────────────────────────────────────────────
# The Next.js frontend already uses 3000, so run Eve on a different port and point
# EVE_SERVICE_URL on the backend at the same value.
PORT=3001
