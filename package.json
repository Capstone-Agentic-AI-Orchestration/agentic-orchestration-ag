{
  "name": "agentic-orchestration-ag",
  "version": "0.1.0",
  "private": true,
  "description": "Agentic Orchestration code-generation agents on Vercel Eve",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "scripts": {
    "dev": "eve dev",
    "build": "eve build",
    "start": "eve start --host 0.0.0.0",
    "typecheck": "tsc -p tsconfig.json --noEmit",
    "test": "node scripts/verify-contract-fixtures.mjs && node scripts/run-eve-hardening-smoke.mjs",
    "test:eve-hardening": "node scripts/run-eve-hardening-smoke.mjs",
    "deploy": "eve deploy",
    "deploy:vercel": "vercel deploy"
  },
  "dependencies": {
    "eve": "^0.13.8",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "typescript": "^6.0.3"
  }
}
